APP_ENV=production
POSTGRES_USER=ervis
POSTGRES_PASSWORD=replace_with_production_secret
POSTGRES_DB=ervis_core
DATABASE_URL=postgresql://ervis:replace_with_production_secret@db:5432/ervis_core
OPENAI_API_KEY=sk-...
JWT_SECRET_KEY=replace_with_long_random_value
CHAT_HISTORY_MAX_MESSAGES_PER_USER=200
CHAT_HISTORY_DEFAULT_FETCH_LIMIT=40
CHAT_HISTORY_MAX_FETCH_LIMIT=80
CHAT_HISTORY_MESSAGE_MAX_CHARS=3000
CHAT_CONVERSATION_DEFAULT_FETCH_LIMIT=20
CHAT_CONVERSATION_MAX_FETCH_LIMIT=40

# Optional setup/verification values
ERVIS_SEED_USERNAME=Prod User
ERVIS_SEED_EMAIL=prod@example.com
ERVIS_SEED_PASSWORD=replace_with_strong_password
ERVIS_TEST_USER=Prod User
ERVIS_TEST_EMAIL=prod@example.com
ERVIS_TEST_PASS=replace_with_strong_password
ERVIS_BASE_URL=http://backend:8000
