{
  "name": "ervis-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:local": "npm run db:start && npm run db:migrate:deploy && npm run dev",
    "build": "next build",
    "start": "next start",
    "start:prod": "node ./scripts/startup.mjs",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:start": "node ./scripts/local-db-compose.mjs start",
    "db:stop": "node ./scripts/local-db-compose.mjs stop",
    "db:logs": "node ./scripts/local-db-compose.mjs logs",
    "db:down": "node ./scripts/local-db-compose.mjs down",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "node ./scripts/migrate-deploy.mjs",
    "db:push": "prisma db push",
    "db:reset:baseline": "prisma migrate reset --force --skip-generate --skip-seed",
    "db:reset:local": "node ./scripts/local-db-compose.mjs reset",
    "db:seed": "tsx prisma/seed.ts",
    "test": "tsx --test tests/*.test.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/client": "^5.22.0",
    "clsx": "^2.1.1",
    "next": "14.2.32",
    "next-auth": "^4.24.14",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tailwind-merge": "^2.5.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.32",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
