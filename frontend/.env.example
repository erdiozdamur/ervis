# Local: development
# Test: use .env.test with NODE_ENV="test"
# Production/Dokploy: set values in the platform env UI instead of committing a prod env file
NODE_ENV="development"
PORT="3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
APP_TIME_ZONE="Europe/Istanbul"
TZ="Europe/Istanbul"

# Database
DATABASE_URL="postgresql://ervis:ervis@localhost:5432/ervis?schema=public"
POSTGRES_USER="ervis"
POSTGRES_PASSWORD="ervis"
POSTGRES_DB="ervis"
POSTGRES_HOST="127.0.0.1"
POSTGRES_PORT="5432"

# Auth
AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_TRUST_HOST="true"
NEXTAUTH_URL="http://localhost:3000"
AUTH_SESSION_MAX_AGE_DAYS="30"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# AI
AI_PROVIDER="openai"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1-mini"
OPENAI_TRANSCRIPTION_MODEL="gpt-4o-mini-transcribe"
AI_ANALYSIS_PROMPT_VERSION="meal-intake-v1"
MEAL_ANALYSIS_STAGE1_MODEL="gpt-4.1-mini"
MEAL_ANALYSIS_STAGE2_MODEL="gpt-4.1-mini"

# Meal asset storage
MEAL_ASSET_STORAGE_DRIVER="local"
MEAL_ASSET_LOCAL_DIR=".uploads/meal-assets"
MEAL_ASSET_MAX_FILE_SIZE_MB="12"

# Startup controls
APPLY_MIGRATIONS_ON_STARTUP="false"
WAIT_FOR_DATABASE_ON_STARTUP="false"
STARTUP_DB_WAIT_TIMEOUT_MS="60000"
STARTUP_DB_WAIT_INTERVAL_MS="2000"
ALLOW_DESTRUCTIVE_BASELINE_RESET="false"
