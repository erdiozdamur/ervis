generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MealStatus {
  DRAFT
  CONFIRMED
  ARCHIVED
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
  OTHER
}

enum MealInputAssetType {
  IMAGE
  AUDIO
  TEXT
  BARCODE
}

enum MealAnalysisStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum SharedNutritionSource {
  OFFICIAL_DATASET
  USER_CONFIRMED
  AI_ESTIMATE
}

enum ProfileSex {
  FEMALE
  MALE
}

enum ProfileGoalType {
  LOSE_FAT
  MAINTAIN
  GAIN_MUSCLE
}

enum ProfileActivityLevel {
  SEDENTARY
  LIGHT
  MODERATE
  ACTIVE
  VERY_ACTIVE
}

enum UserRole {
  USER
  ADMIN
  OWNER
}

model AppMeta {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AppSetting {
  key       String   @id @db.VarChar(191)
  valueJson Json
  type      String   @db.VarChar(64)
  scope     String   @db.VarChar(64)
  isSecret  Boolean  @default(false)
  updatedBy String?  @db.VarChar(191)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([scope, type])
  @@map("app_settings")
}

/// Core auth user record. All user-owned product data hangs off this model.
model User {
  id               String            @id @default(cuid())
  name             String?
  email            String            @unique
  role             UserRole          @default(USER)
  emailVerified    DateTime?
  image            String?
  passwordHash     String?
  profile          UserProfile?
  meals            Meal[]
  mealInputAssets  MealInputAsset[]
  mealAnalysisRuns MealAnalysisRun[]
  accounts         Account[]
  sessions         Session[]
  adminAuditLogs   AdminAuditLog[]   @relation("AdminAuditActor")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@map("users")
}

/// Reserved for auth provider connections so social login can be added later.
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("auth_accounts")
}

/// Database-backed secure sessions for authenticated users.
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("auth_sessions")
}

/// Verification token storage for future email verification / recovery flows.
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("auth_verification_tokens")
}

/// One-to-one per-user app profile and preferences.
model UserProfile {
  userId                   String                @id
  timeZone                 String                @default("Europe/Istanbul")
  preferredLanguage        String?               @db.VarChar(16)
  age                      Int?
  sex                      ProfileSex?
  heightCm                 Int?
  weightKg                 Decimal?              @db.Decimal(5, 2)
  goalType                 ProfileGoalType?
  activityLevel            ProfileActivityLevel?
  trainingFrequencyPerWeek Int?
  dailyCalorieGoal         Int?
  macroProteinGrams        Int?
  macroCarbGrams           Int?
  macroFatGrams            Int?
  calculatorVersion        String?               @db.VarChar(32)
  targetCalculatedAt       DateTime?
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt
  user                     User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

/// User-owned meal container. `mealDate` is the Europe/Istanbul-local day bucket used for grouping.
model Meal {
  id           String            @id @default(cuid())
  userId       String
  status       MealStatus        @default(DRAFT)
  mealType     MealType          @default(OTHER)
  title        String?           @db.VarChar(120)
  notes        String?
  timeZone     String            @default("Europe/Istanbul")
  mealDate     DateTime          @db.Date
  consumedAt   DateTime          @default(now())
  confirmedAt  DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  items        MealItem[]
  inputAssets  MealInputAsset[]
  analysisRuns MealAnalysisRun[]

  @@index([userId, mealDate, consumedAt])
  @@index([userId, status, createdAt])
  @@map("meals")
}

/// Itemized foods inside a meal, including AI drafts and user-confirmed edits.
model MealItem {
  id                    String               @id @default(cuid())
  mealId                String
  sortOrder             Int                  @default(0)
  displayName           String               @db.VarChar(160)
  quantityAmount        Decimal?             @db.Decimal(10, 2)
  quantityUnit          String?              @db.VarChar(32)
  gramsEstimate         Decimal?             @db.Decimal(10, 2)
  calories              Decimal?             @db.Decimal(10, 2)
  proteinGrams          Decimal?             @db.Decimal(10, 2)
  carbGrams             Decimal?             @db.Decimal(10, 2)
  fatGrams              Decimal?             @db.Decimal(10, 2)
  fiberGrams            Decimal?             @db.Decimal(10, 2)
  normalizedFoodEntryId String?
  nutritionCacheEntryId String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  meal                  Meal                 @relation(fields: [mealId], references: [id], onDelete: Cascade)
  normalizedFoodEntry   FoodCatalogEntry?    @relation(fields: [normalizedFoodEntryId], references: [id], onDelete: SetNull)
  nutritionCacheEntry   NutritionCacheEntry? @relation(fields: [nutritionCacheEntryId], references: [id], onDelete: SetNull)

  @@index([mealId, sortOrder])
  @@index([normalizedFoodEntryId])
  @@index([nutritionCacheEntryId])
  @@map("meal_items")
}

/// Raw user meal inputs such as photos, text, or barcodes that feed AI analysis.
model MealInputAsset {
  id            String             @id @default(cuid())
  mealId        String
  userId        String
  assetType     MealInputAssetType
  sortOrder     Int                @default(0)
  textContent   String?
  storageKey    String?            @db.VarChar(255)
  mimeType      String?            @db.VarChar(128)
  sha256        String?            @db.VarChar(128)
  fileSizeBytes Int?
  metadataJson  Json?
  createdAt     DateTime           @default(now())
  meal          Meal               @relation(fields: [mealId], references: [id], onDelete: Cascade)
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([mealId, sortOrder])
  @@index([userId, createdAt])
  @@index([sha256])
  @@map("meal_input_assets")
}

/// Tracks each AI analysis attempt, including cached/draft JSON before user confirmation.
model MealAnalysisRun {
  id                 String             @id @default(cuid())
  mealId             String
  userId             String
  status             MealAnalysisStatus @default(QUEUED)
  provider           String             @db.VarChar(64)
  model              String             @db.VarChar(128)
  promptVersion      String?            @db.VarChar(64)
  requestFingerprint String             @db.VarChar(128)
  requestJson        Json?
  responseJson       Json?
  draftResultJson    Json?
  errorMessage       String?
  startedAt          DateTime?
  completedAt        DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  meal               Meal               @relation(fields: [mealId], references: [id], onDelete: Cascade)
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([mealId, createdAt])
  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([requestFingerprint])
  @@map("meal_analysis_runs")
}

/// Shared, normalized food entries that can be reused by every user and linked from meal items.
model FoodCatalogEntry {
  id                    String                @id @default(cuid())
  slug                  String                @unique @db.VarChar(191)
  canonicalName         String                @db.VarChar(191)
  brandName             String?               @db.VarChar(191)
  source                SharedNutritionSource @default(OFFICIAL_DATASET)
  externalSourceName    String?               @db.VarChar(64)
  externalSourceId      String?               @db.VarChar(128)
  defaultServingAmount  Decimal?              @db.Decimal(10, 2)
  defaultServingUnit    String?               @db.VarChar(32)
  calories              Decimal?              @db.Decimal(10, 2)
  proteinGrams          Decimal?              @db.Decimal(10, 2)
  carbGrams             Decimal?              @db.Decimal(10, 2)
  fatGrams              Decimal?              @db.Decimal(10, 2)
  fiberGrams            Decimal?              @db.Decimal(10, 2)
  metadataJson          Json?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  mealItems             MealItem[]
  nutritionCacheEntries NutritionCacheEntry[]

  @@index([canonicalName])
  @@index([externalSourceName, externalSourceId])
  @@map("food_catalog_entries")
}

/// Shared nutrition cache for normalized or AI-estimated foods reused across all users.
model NutritionCacheEntry {
  id                    String                @id @default(cuid())
  cacheKey              String                @unique @db.VarChar(191)
  normalizedQueryText   String                @db.VarChar(191)
  source                SharedNutritionSource @default(AI_ESTIMATE)
  provider              String?               @db.VarChar(64)
  normalizedFoodEntryId String?
  servingAmount         Decimal?              @db.Decimal(10, 2)
  servingUnit           String?               @db.VarChar(32)
  calories              Decimal?              @db.Decimal(10, 2)
  proteinGrams          Decimal?              @db.Decimal(10, 2)
  carbGrams             Decimal?              @db.Decimal(10, 2)
  fatGrams              Decimal?              @db.Decimal(10, 2)
  fiberGrams            Decimal?              @db.Decimal(10, 2)
  payloadJson           Json?
  expiresAt             DateTime?
  lastUsedAt            DateTime?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  normalizedFoodEntry   FoodCatalogEntry?     @relation(fields: [normalizedFoodEntryId], references: [id], onDelete: SetNull)
  mealItems             MealItem[]

  @@index([normalizedQueryText])
  @@index([normalizedFoodEntryId])
  @@index([expiresAt])
  @@map("nutrition_cache_entries")
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  actorUserId String
  action      String   @db.VarChar(191)
  targetType  String   @db.VarChar(120)
  targetId    String?  @db.VarChar(191)
  beforeState Json?
  afterState  Json?
  metadata    Json?
  createdAt   DateTime @default(now())
  actorUser   User     @relation("AdminAuditActor", fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([actorUserId, createdAt])
  @@index([targetType, targetId, createdAt])
  @@index([action, createdAt])
  @@map("admin_audit_logs")
}
