generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "debian-openssl-3.0.x"]
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

enum UserRole {
  USER
  ADMIN
}

enum EntityStatus {
  ACTIVE
  ARCHIVED
}

enum ContextOwnerType {
  ORGANIZATION
  TEAM
  EMPLOYEE
}

enum ContextSourceType {
  TEXT
  DOCUMENT_REFERENCE
  NOTE
}

enum ModelPreference {
  GPT_4_1
  GPT_4O
  GPT_4O_MINI
}

enum EdgeType {
  HIERARCHY
  HANDOFF
  APPROVAL
  FEEDBACK_LOOP
  ESCALATION
}

enum AuditAction {
  ORGANIZATION_CREATED
  ORGANIZATION_UPDATED
  TEAM_CREATED
  TEAM_UPDATED
  EMPLOYEE_CREATED
  EMPLOYEE_UPDATED
  EDGE_CREATED
  EDGE_UPDATED
  EDGE_DELETED
  CONTEXT_SOURCE_CREATED
  CONTEXT_SOURCE_UPDATED
  CONTEXT_SOURCE_DELETED
  CAPABILITY_ASSIGNED
  CAPABILITY_REMOVED
  ENTITY_ARCHIVED
  ENTITY_DELETED
  NODE_MOVED
}

model User {
  id             String                @id @default(cuid())
  email          String                @unique
  name           String?
  image          String?
  passwordHash   String?
  role           UserRole              @default(USER)
  organizations  Organization[]
  accounts       Account[]
  sessions       Session[]
  auditLogs      AuditLog[]
  employeeCaps   EmployeeCapability[]
  teamCaps       TeamCapability[]
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
}

model Organization {
  id            String           @id @default(cuid())
  ownerId       String
  name          String
  description   String           @default("")
  status        EntityStatus     @default(ACTIVE)
  tags          String[]         @default([])
  attributes    Json             @default("{}")
  instructions  String           @default("")
  context       String           @default("")
  teams         Team[]
  employees     Employee[]
  teamEdges     TeamEdge[]
  contextSource ContextSource[]
  auditLogs     AuditLog[]
  owner         User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([ownerId])
}

model Team {
  id              String           @id @default(cuid())
  organizationId  String
  parentTeamId    String?
  name            String
  instructions    String           @default("")
  positionX       Float            @default(0)
  positionY       Float            @default(0)
  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parentTeam      Team?            @relation("TeamHierarchy", fields: [parentTeamId], references: [id])
  childTeams      Team[]           @relation("TeamHierarchy")
  employees       Employee[]
  sourceEdges     TeamEdge[]       @relation("TeamEdgeSource")
  targetEdges     TeamEdge[]       @relation("TeamEdgeTarget")
  employeeEdges   EmployeeEdge[]
  capabilities    TeamCapability[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([organizationId])
  @@index([parentTeamId])
}

model Employee {
  id               String               @id @default(cuid())
  organizationId   String
  teamId           String
  managerId        String?
  name             String
  modelPreference  ModelPreference      @default(GPT_4O_MINI)
  instructions     String               @default("")
  positionX        Float                @default(0)
  positionY        Float                @default(0)
  organization     Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team             Team                 @relation(fields: [teamId], references: [id], onDelete: Cascade)
  manager          Employee?            @relation("EmployeeHierarchy", fields: [managerId], references: [id])
  directReports    Employee[]           @relation("EmployeeHierarchy")
  sourceEdges      EmployeeEdge[]       @relation("EmployeeEdgeSource")
  targetEdges      EmployeeEdge[]       @relation("EmployeeEdgeTarget")
  capabilities     EmployeeCapability[]
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([organizationId])
  @@index([teamId])
}

model Capability {
  id           String               @id @default(cuid())
  key          String               @unique
  label        String
  description  String?
  employees    EmployeeCapability[]
  teams        TeamCapability[]
  createdAt    DateTime             @default(now())
}

model EmployeeCapability {
  id            String      @id @default(cuid())
  employeeId    String
  capabilityId  String
  grantedById   String
  employee      Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  capability    Capability  @relation(fields: [capabilityId], references: [id], onDelete: Cascade)
  grantedBy     User        @relation(fields: [grantedById], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@unique([employeeId, capabilityId])
}

model TeamCapability {
  id            String      @id @default(cuid())
  teamId         String
  capabilityId   String
  grantedById    String
  team           Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  capability     Capability @relation(fields: [capabilityId], references: [id], onDelete: Cascade)
  grantedBy      User       @relation(fields: [grantedById], references: [id], onDelete: Cascade)
  createdAt      DateTime   @default(now())

  @@unique([teamId, capabilityId])
}

model TeamEdge {
  id              String       @id @default(cuid())
  organizationId  String
  sourceTeamId    String
  targetTeamId    String
  edgeType        EdgeType     @default(HIERARCHY)
  label           String?
  description     String       @default("")
  conditionNote   String       @default("")
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sourceTeam      Team         @relation("TeamEdgeSource", fields: [sourceTeamId], references: [id], onDelete: Cascade)
  targetTeam      Team         @relation("TeamEdgeTarget", fields: [targetTeamId], references: [id], onDelete: Cascade)
  createdAt       DateTime     @default(now())

  @@index([organizationId])
}

model EmployeeEdge {
  id               String       @id @default(cuid())
  teamId           String
  sourceEmployeeId String
  targetEmployeeId String
  edgeType         EdgeType     @default(HANDOFF)
  label            String?
  description      String       @default("")
  conditionNote    String       @default("")
  team             Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  sourceEmployee   Employee     @relation("EmployeeEdgeSource", fields: [sourceEmployeeId], references: [id], onDelete: Cascade)
  targetEmployee   Employee     @relation("EmployeeEdgeTarget", fields: [targetEmployeeId], references: [id], onDelete: Cascade)
  createdAt        DateTime     @default(now())

  @@index([teamId])
}

model ContextSource {
  id                String            @id @default(cuid())
  organizationId    String
  ownerType         ContextOwnerType
  ownerId           String
  title             String
  type              ContextSourceType @default(TEXT)
  content           String
  embedding         Unsupported("vector")?
  metadata          Json              @default("{}")
  organization      Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([organizationId, ownerType])
}

model AuditLog {
  id              String        @id @default(cuid())
  organizationId  String?
  actorId         String
  action          AuditAction
  subjectType     String
  subjectId       String
  metadata        Json          @default("{}")
  actor           User          @relation(fields: [actorId], references: [id], onDelete: Cascade)
  organization    Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())

  @@index([organizationId, createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
